{
  "name": "renotasker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "kill-port 3000 && next dev --webpack",
    "dev:no-kill": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "supabase:db:push": "npx supabase db push",
    "supabase:link": "npx supabase link",
    "supabase:functions:deploy-invite": "npx supabase functions deploy send-project-invite",
    "verify:supabase": "node scripts/verify-supabase-migration.mjs",
    "verify:invite": "node scripts/verify-invite-email-setup.mjs",
    "probe:edge": "node scripts/probe-edge-functions.mjs",
    "supabase:functions:deploy-invite:staging": "npx supabase functions deploy send-project-invite --project-ref cgvmclxglxhbuhuovedl --no-verify-jwt",
    "supabase:functions:deploy-invite:prod": "npx supabase functions deploy send-project-invite --project-ref qvansiwlykvhgfdygisu --no-verify-jwt",
    "supabase:functions:deploy-auth-email:staging": "npx supabase functions deploy send-auth-email --project-ref cgvmclxglxhbuhuovedl --no-verify-jwt",
    "supabase:functions:deploy-auth-email:prod": "npx supabase functions deploy send-auth-email --project-ref qvansiwlykvhgfdygisu --no-verify-jwt",
    "supabase:functions:deploy-email:staging": "npm run supabase:functions:deploy-invite:staging && npm run supabase:functions:deploy-auth-email:staging",
    "supabase:functions:deploy-email:prod": "npm run supabase:functions:deploy-invite:prod && npm run supabase:functions:deploy-auth-email:prod",
    "sync:supabase-storage": "node scripts/sync-supabase-storage-documents.mjs",
    "brand:logo": "node scripts/build-renotasker-logo-transparent.mjs",
    "cleanup:pw-e2e": "node scripts/cleanup-pw-e2e-projects.mjs",
    "cleanup:pw-e2e:dry-run": "node scripts/cleanup-pw-e2e-projects.mjs --dry-run",
    "export:bouwdepot-declaraties": "node scripts/export-bouwdepot-declaraties.mjs"
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/postcss": "^4",
    "@types/three": "^0.184.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-joyride": "^3.0.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "kill-port": "^2.0.1",
    "supabase": "^2.100.1",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
